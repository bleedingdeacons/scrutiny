<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.6/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         cacheResultFile=".phpunit.result.cache">
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
            <!--
                A test double, not a test case. Its name ends in "Test.php",
                so PHPUnit collects it and then reports that it does not
                extend TestCase.
            -->
            <exclude>tests/Unit/Cleanup/MemberPrunerForTest.php</exclude>
        </testsuite>
    </testsuites>
    <coverage>
        <include>
            <directory suffix=".php">src</directory>
        </include>
        <exclude>
            <!--
                Admin screens are WordPress render/callback glue (list tables,
                settings fields, meta boxes, menu registration) exercised
                through WordPress at runtime rather than in unit tests, so they
                are excluded from the coverage denominator — the same call
                Reach and Integrity make for their own src/Admin.
            -->
            <directory suffix=".php">src/Admin</directory>
            <!--
                Interface files carry no executable behaviour beyond the
                `if (!defined('ABSPATH')) exit;` guard, so there is nothing to
                unit-test in them.
            -->
            <directory suffix=".php">src/Audit/Interfaces</directory>
        </exclude>
    </coverage>
</phpunit>
